Part 3: Test-Driven Development
3.1 TDD for New Feature — Assigned User Boost (+12)
TDD rule: Write a FAILING test first, then write minimal code to make it pass.

Step 1 — Failing Test First
def test_assigned_to_current_user_adds_12_points():
    """TDD: This test fails BEFORE feature is added."""
    task = Task(
        title='My task',
        priority=TaskPriority.LOW,
        assigned_to='current_user'
    )
    score = calculate_task_score(task, current_user='current_user')
    assert score == 22  # 10 + 12

Step 2 — Minimal Code to Pass
def calculate_task_score(task, current_user=None):
    # ... existing code unchanged ...
    # NEW: boost for assigned user
    if current_user and hasattr(task, 'assigned_to'):
        if task.assigned_to == current_user:
            score += 12
    return score

Step 3 — Next Tests
def test_unassigned_task_gets_no_boost():
    task = Task(title='Other task', priority=TaskPriority.LOW,
                assigned_to='other_user')
    score = calculate_task_score(task, current_user='current_user')
    assert score == 10  # no boost

def test_no_current_user_gets_no_boost():
    task = Task(title='Task', priority=TaskPriority.LOW,
                assigned_to='current_user')
    score = calculate_task_score(task)  # no current_user param
    assert score == 10  # no boost

def test_assigned_boost_combines_with_overdue():
    task = Task(title='My overdue task', priority=TaskPriority.LOW,
                due_date=datetime.now() - timedelta(days=1),
                assigned_to='current_user')
    score = calculate_task_score(task, current_user='current_user')
    assert score == 57  # 10 + 35 + 12

