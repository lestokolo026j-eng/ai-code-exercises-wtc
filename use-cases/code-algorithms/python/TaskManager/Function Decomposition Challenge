Pattern Applied: Strategy Pattern (Dictionary Dispatch)
def generate_output(report_data, output_format, include_charts):
    """
    Generates the final report in the requested format
    using the Strategy pattern (dictionary dispatch).
    """
    output_strategies = {
        'json': lambda: report_data,
        'html': lambda: _generate_html_report(report_data, include_charts),
        'excel': lambda: _generate_excel_report(report_data, include_charts),
        'pdf': lambda: _generate_pdf_report(report_data, include_charts)
    }
    return output_strategies[output_format]()

